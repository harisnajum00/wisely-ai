# Wisely AI - Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API Key (required for AI text chat)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Ollama Configuration (optional — for local image analysis, no rate limits!)
# Install Ollama: https://ollama.com
# Then run: ollama pull gemma4
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4

# Database URL (PostgreSQL for production)
DATABASE_URL=postgresql://user:password@host:5432/wisely_ai

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here
